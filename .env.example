# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Credentials (SaaS Configuration)
# If left empty, the app will use the system-generated project
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIREBASE_DATABASE_ID=""

# Backend-only Firebase Secret (Optional override for Admin SDK)
FIREBASE_PROJECT_ID=""
FIREBASE_DATABASE_ID=""
FIREBASE_SERVICE_ACCOUNT_JSON=""

# JWT Token Secret for Express API session authentication
JWT_SECRET="collabdocs_secret_v1"

# MongoDB Atlas URI (SaaS Cloud Sync Connection)
# Example: mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGODB_URI=""
VITE_MONGODB_URI=""

# Razorpay API Credentials for Subscription Processing
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# SMTP Email Config (Nodemailer system dispatch)
SMTP_EMAIL=""
SMTP_PASSWORD=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_FROM_EMAIL=""

# Google Analytics
VITE_GA_MEASUREMENT_ID=
